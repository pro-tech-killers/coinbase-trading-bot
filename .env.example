# Copy to .env and fill in. Never commit .env.
#
# Coinbase Advanced Trade — CDP API key (recommended):
# https://www.coinbase.com/settings/api or Cloud console
CDP_API_KEY_NAME=
CDP_API_KEY_SECRET=
#
# Or legacy HMAC key + secret (older Coinbase key format):
# API_KEY=
# API_SECRET=
#
# Paper mode: set to 0 to place real market orders (you still need keys for data).
PAPER_TRADING=1
PRODUCT_ID=BTC-USD
CANDLE_GRANULARITY=FIVE_MINUTE
POLL_MS=60000
EMA_FAST=12
EMA_SLOW=26
EMA_TREND=200
ATR_PERIOD=14
RISK_PER_TRADE=0.02
# Optional cap per buy (quote currency, e.g. USD)
# MAX_QUOTE_PER_ORDER=500
