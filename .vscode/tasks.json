{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: install all dependencies",
      "type": "shell",
      "command": "npm install --include=dev --include=optional --production=false",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "NODE_ENV": "development",
          "NPM_CONFIG_PRODUCTION": "false",
          "NPM_CONFIG_OMIT": ""
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    }
  ]
}
